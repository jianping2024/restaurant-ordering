NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 本站公网地址（打印助手下载固定为 {BASE_URL}/api/downloads/print-agent/...）
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 打印助手 GitHub 仓库（Release 资源名固定；发布 tag：print-agent-v*）
NEXT_PUBLIC_PRINT_AGENT_GITHUB_REPO=jianping2024/restaurant-ordering
# 可选：覆盖打印助手下载页显示的版本（默认读 apps/print-agent/VERSION）
# NEXT_PUBLIC_PRINT_AGENT_VERSION=0.2.0

# 管理员创建店主账号（服务端，勿提交到仓库）
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_BOOTSTRAP_SECRET=use_a_long_random_string

# 打印助手 claim JWT 签名（仅服务端，勿提交）
PRINT_AGENT_JWT_SECRET=use_a_long_random_string_at_least_16_chars

# 厨房/服务员 HttpOnly 会话签名（仅服务端；可省略则回退 PRINT_AGENT_JWT_SECRET）
STAFF_SESSION_SECRET=use_a_long_random_string_at_least_16_chars

# 下单后打印入队签名（仅服务端；可省略则回退 STAFF_SESSION_SECRET）
ORDER_ENQUEUE_SECRET=use_a_long_random_string_at_least_16_chars

# Vercel Cron 鉴权（部署到 Vercel 后在项目环境变量中设置；Vercel 也会自动注入 CRON_SECRET）
CRON_SECRET=use_a_long_random_string

# 可选：本地脚本 / GitHub CLI（非 Next 运行时必需；勿提交真实 token）
# GH_TOKEN=
