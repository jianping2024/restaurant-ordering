{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "cd ../.. && npm ci",
  "ignoreCommand": "bash ../../scripts/vercel-ignore-web.sh",
  "crons": [
    {
      "path": "/api/cron/expire-stale-print-jobs",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/nightly-close-sessions",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/nightly-close-sessions",
      "schedule": "0 5 * * *"
    }
  ]
}
