# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/
apps/*/.next/
apps/*/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files (`.env*` also covers `.env*.local`; keep example tracked)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase cli local state
supabase/.branches/

# supabase cli local cache
supabase/.temp/

# local agent / IDE
.claude/

# Turborepo
.turbo

# cloud → staging sync artifacts (may contain production data)
.sync-tmp/

# local git worktrees (full checkouts; do not commit)
.worktrees/
