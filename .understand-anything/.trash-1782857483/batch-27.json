      "tags": ["dom", "wizard", "render"],
      "complexity": "moderate"
    },
    {
      "id": "function:apps/print-agent/setup_ui.html:applyI18nLabels",
      "type": "function",
      "name": "applyI18nLabels",
      "filePath": "apps/print-agent/setup_ui.html",
      "lineRange": [128, 151],
      "summary": "将 setup 页面所有静态标签替换为当前 ui 字典中的 zh/en/pt 文案，不重建站点行或打印机下拉框。",
      "tags": ["i18n", "utility", "wizard"],
      "complexity": "simple"
    },
    {
      "id": "function:apps/print-agent/pair_ui.html:loadI18n",
      "type": "function",
      "name": "loadI18n",
