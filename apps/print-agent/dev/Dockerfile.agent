# Build print-agent for dev only (not production Windows image).
FROM golang:1.22-alpine AS build
WORKDIR /src
COPY go.mod ./
COPY *.go ./
RUN go build -o /mesa-print-agent .

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /mesa-print-agent /usr/local/bin/mesa-print-agent
WORKDIR /data
ENTRYPOINT ["mesa-print-agent"]
